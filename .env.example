# Get a FREE Gemini API key at https://aistudio.google.com (Get API key). No billing required.
# Copy this file to .env and paste your key. .env is gitignored — never commit it.
GEMINI_API_KEY=

# Optional overrides (defaults shown):
# gemini-flash-latest tracks the current stable Flash model (avoids deprecation churn).
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIMS=768

# If you are behind an HTTP proxy (e.g. a corporate/dev network), the app needs it to
# reach Google's APIs. Uncomment and set; leave unset on a normal machine.
# https_proxy=http://your-proxy:port
# http_proxy=http://your-proxy:port
